# Copy this file to .env.local and populate with your values

# Neon pooled connection string (for neon() HTTP client — most queries)
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.us-east-1.aws.neon.tech/neondb?sslmode=require

# Neon direct (non-pooling) connection string (for /api/setup DDL via Pool)
DATABASE_URL_UNPOOLED=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# Shared secret for Pi → API authentication (x-api-key header)
INGEST_SECRET=your-strong-random-secret-here

# opentransportdata.swiss GTFS Realtime API key
GTFS_RT_API_KEY=your-gtfs-rt-api-key-here

# App title (shown in UI)
NEXT_PUBLIC_APP_TITLE=TramWatch
